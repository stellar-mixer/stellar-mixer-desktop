{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stellar Mixer",
  "version": "0.1.0",
  "identifier": "com.samvinchester.stellar-mixer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Stellar Mixer",
        "width": 1180,
        "height": 780,
        "minWidth": 980,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
